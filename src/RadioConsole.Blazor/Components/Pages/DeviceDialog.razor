@using RadioConsole.Api.Models
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using MudBlazor
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_isFormValid">
                <MudSelect T="string" 
                           Label="Device Type" 
                           @bind-Value="_selectedDeviceType"
                           Required="true"
                           Disabled="IsEditMode"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var type in _availableTypes)
                    {
                        <MudSelectItem Value="@type.TypeName">@type.DisplayName</MudSelectItem>
                    }
                </MudSelect>

                @if (!string.IsNullOrEmpty(_selectedDeviceType))
                {
                    var selectedType = _availableTypes.FirstOrDefault(t => t.TypeName == _selectedDeviceType);
                    if (selectedType != null)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2 mb-3">@selectedType.Description</MudText>
                    }
                }

                <MudTextField T="string" 
                              Label="Name" 
                              @bind-Value="_deviceName"
                              Required="true"
                              Variant="Variant.Outlined"
                              HelperText="Give this device a friendly name" />

                <MudTextField T="string" 
                              Label="Description" 
                              @bind-Value="_deviceDescription"
                              Variant="Variant.Outlined"
                              Lines="2"
                              HelperText="Optional description for this device" />

                <!-- Device-specific parameters -->
                @if (!string.IsNullOrEmpty(_selectedDeviceType))
                {
                    var selectedType = _availableTypes.FirstOrDefault(t => t.TypeName == _selectedDeviceType);
                    if (selectedType != null && selectedType.Parameters.Any())
                    {
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.h6" Class="mb-2">Device Parameters</MudText>

                        @foreach (var param in selectedType.Parameters)
                        {
                            <div class="mb-3">
                                @if (param.DataType == "int")
                                {
                                    var value = GetParameterValue<int>(param.Name, GetDefaultValue<int>(param.DefaultValue, 0));
                                    <MudNumericField T="int" 
                                                     Label="@param.DisplayName" 
                                                     Value="@value"
                                                     ValueChanged="@(v => SetParameterValue(param.Name, v))"
                                                     Required="@param.Required"
                                                     Variant="Variant.Outlined"
                                                     HelperText="@param.Description" />
                                }
                                else if (param.DataType == "bool")
                                {
                                    var value = GetParameterValue<bool>(param.Name, GetDefaultValue<bool>(param.DefaultValue, false));
                                    <MudSwitch T="bool" 
                                               Label="@param.DisplayName"
                                               Value="@value"
                                               ValueChanged="@((bool v) => SetParameterValue(param.Name, v))"
                                               Color="Color.Primary" />
                                    <MudText Typo="Typo.caption">@param.Description</MudText>
                                }
                                else
                                {
                                    var value = GetParameterValue<string>(param.Name, GetDefaultValue<string>(param.DefaultValue, ""));
                                    <MudTextField T="string" 
                                                  Label="@param.DisplayName" 
                                                  Value="@value"
                                                  ValueChanged="@(v => SetParameterValue(param.Name, v))"
                                                  Required="@param.Required"
                                                  Variant="Variant.Outlined"
                                                  HelperText="@param.Description" />
                                }
                            </div>
                        }
                    }
                }

                <MudSwitch T="bool" 
                           Label="Enable this device"
                           @bind-Value="_isEnabled"
                           Color="Color.Primary"
                           Class="mt-3" />
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="Save"
                   Disabled="!_isFormValid || _saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>@(IsEditMode ? "Update" : "Add")</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    private IDialogReference MudDialog { get; set; } = null!;

    [Parameter]
    public bool IsInput { get; set; }

    [Parameter]
    public bool IsEditMode { get; set; }

    [Parameter]
    public DeviceConfigurationResponse? Device { get; set; }

    private MudForm _form = null!;
    private bool _isFormValid;
    private bool _loading = true;
    private bool _saving = false;

    private List<DeviceTypeInfo> _availableTypes = new();
    private string _selectedDeviceType = string.Empty;
    private string _deviceName = string.Empty;
    private string _deviceDescription = string.Empty;
    private bool _isEnabled = true;
    private Dictionary<string, object> _parameters = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableTypes();

        if (IsEditMode && Device != null)
        {
            _selectedDeviceType = Device.DeviceType;
            _deviceName = Device.Name;
            _deviceDescription = Device.Description;
            _isEnabled = Device.IsEnabled;
            _parameters = new Dictionary<string, object>(Device.Parameters);
        }

        _loading = false;
    }

    private async Task LoadAvailableTypes()
    {
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri("http://localhost:5000");

            var endpoint = IsInput ? "/api/devices/types/inputs" : "/api/devices/types/outputs";
            _availableTypes = await client.GetFromJsonAsync<List<DeviceTypeInfo>>(endpoint) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading device types: {ex.Message}", Severity.Error);
        }
    }

    private T GetParameterValue<T>(string key, T defaultValue)
    {
        if (_parameters.TryGetValue(key, out var value))
        {
            if (value is JsonElement jsonElement)
            {
                try
                {
                    return JsonSerializer.Deserialize<T>(jsonElement.GetRawText()) ?? defaultValue;
                }
                catch
                {
                    return defaultValue;
                }
            }
            if (value is T typedValue)
            {
                return typedValue;
            }
            try
            {
                return (T)Convert.ChangeType(value, typeof(T));
            }
            catch
            {
                return defaultValue;
            }
        }
        return defaultValue;
    }

    private T GetDefaultValue<T>(object? value, T fallback)
    {
        if (value == null)
        {
            return fallback;
        }

        if (value is JsonElement jsonElement)
        {
            try
            {
                return JsonSerializer.Deserialize<T>(jsonElement.GetRawText()) ?? fallback;
            }
            catch
            {
                return fallback;
            }
        }

        if (value is T typedValue)
        {
            return typedValue;
        }

        try
        {
            return (T)Convert.ChangeType(value, typeof(T));
        }
        catch
        {
            return fallback;
        }
    }

    private void SetParameterValue(string key, object value)
    {
        _parameters[key] = value;
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Cancel());
    }

    private async Task Save()
    {
        await _form.Validate();

        if (!_isFormValid)
        {
            Snackbar.Add("Please fill in all required fields", Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri("http://localhost:5000");

            var request = new DeviceConfigurationRequest
            {
                DeviceType = _selectedDeviceType,
                Name = _deviceName,
                Description = _deviceDescription,
                Parameters = _parameters,
                IsEnabled = _isEnabled
            };

            var json = JsonSerializer.Serialize(request);
            var content = new StringContent(json, Encoding.UTF8, "application/json");

            HttpResponseMessage response;
            if (IsEditMode && Device != null)
            {
                var endpoint = IsInput ? $"/api/devices/inputs/{Device.Id}" : $"/api/devices/outputs/{Device.Id}";
                response = await client.PutAsync(endpoint, content);
            }
            else
            {
                var endpoint = IsInput ? "/api/devices/inputs" : "/api/devices/outputs";
                response = await client.PostAsync(endpoint, content);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Device {(IsEditMode ? "updated" : "added")} successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to save device: {errorContent}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving device: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
