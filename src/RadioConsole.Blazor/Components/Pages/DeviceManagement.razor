@page "/devices"
@rendermode InteractiveServer
@using RadioConsole.Api.Models
@using RadioConsole.Api.Interfaces
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Device Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Device Management</MudText>
<MudText Typo="Typo.body1" Class="mb-4">Configure audio input and output devices</MudText>

<!-- Music Input Devices Section -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6">Music Input Devices</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="() => OpenAddMusicInputDialog()">
            Add Music Input
        </MudButton>
    </MudStack>

    @if (_loadingInputs)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_musicInputDevices.Any())
    {
        <MudAlert Severity="Severity.Info">No music input devices configured yet.</MudAlert>
    }
    else
    {
        <MudTable Items="_musicInputDevices" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Type">@context.DeviceType</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Status">
                    @if (context.IsEnabled && context.IsAvailable)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Available</MudChip>
                    }
                    else if (context.IsEnabled)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Unavailable</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Disabled</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Size="Size.Small" 
                                   Color="Color.Primary"
                                   OnClick="() => OpenEditInputDialog(context, AudioInputType.Music)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                   Size="Size.Small" 
                                   Color="Color.Error"
                                   OnClick="() => DeleteInput(context.Id)" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<!-- Prompts (Event Audio) Section -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6">Prompts (Event Audio)</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Secondary" 
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="() => OpenAddPromptDialog()">
            Add Prompt
        </MudButton>
    </MudStack>

    @if (_loadingInputs)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_promptDevices.Any())
    {
        <MudAlert Severity="Severity.Info">No prompts configured yet.</MudAlert>
    }
    else
    {
        <MudTable Items="_promptDevices" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Type">@context.DeviceType</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Status">
                    @if (context.IsEnabled && context.IsAvailable)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Available</MudChip>
                    }
                    else if (context.IsEnabled)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Unavailable</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Disabled</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Size="Size.Small" 
                                   Color="Color.Primary"
                                   OnClick="() => OpenEditInputDialog(context, AudioInputType.Event)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                   Size="Size.Small" 
                                   Color="Color.Error"
                                   OnClick="() => DeleteInput(context.Id)" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<!-- Output Devices Section -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6">Audio Output Devices</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="() => OpenAddOutputDialog()">
            Add Output
        </MudButton>
    </MudStack>

    @if (_loadingOutputs)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_outputDevices.Any())
    {
        <MudAlert Severity="Severity.Info">No audio output devices configured yet.</MudAlert>
    }
    else
    {
        <MudTable Items="_outputDevices" Hover="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Type">@context.DeviceType</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Status">
                    @if (context.IsEnabled && context.IsAvailable)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Available</MudChip>
                    }
                    else if (context.IsEnabled)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Unavailable</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Disabled</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Size="Size.Small" 
                                   Color="Color.Primary"
                                   OnClick="() => OpenEditOutputDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                   Size="Size.Small" 
                                   Color="Color.Error"
                                   OnClick="() => DeleteOutput(context.Id)" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private List<DeviceConfigurationResponse> _musicInputDevices = new();
    private List<DeviceConfigurationResponse> _promptDevices = new();
    private List<DeviceConfigurationResponse> _outputDevices = new();
    private bool _loadingInputs = true;
    private bool _loadingOutputs = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevices();
    }

    private async Task LoadDevices()
    {
        _loadingInputs = true;
        _loadingOutputs = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri("http://localhost:5000");

            var inputsTask = client.GetFromJsonAsync<List<DeviceConfigurationResponse>>("/api/devices/inputs");
            var outputsTask = client.GetFromJsonAsync<List<DeviceConfigurationResponse>>("/api/devices/outputs");

            var allInputs = await inputsTask ?? new();
            _outputDevices = await outputsTask ?? new();

            // Separate inputs by type
            _musicInputDevices = allInputs
                .Where(d => d.AudioInputType == null || d.AudioInputType == AudioInputType.Music)
                .ToList();
            _promptDevices = allInputs
                .Where(d => d.AudioInputType == AudioInputType.Event)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading devices: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingInputs = false;
            _loadingOutputs = false;
        }
    }

    private async Task OpenAddMusicInputDialog()
    {
        var parameters = new DialogParameters
        {
            ["IsInput"] = true,
            ["IsEditMode"] = false,
            ["AudioInputType"] = AudioInputType.Music
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<DeviceDialog>("Add Music Input", parameters, options);
        
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadDevices();
        }
    }

    private async Task OpenAddPromptDialog()
    {
        var parameters = new DialogParameters
        {
            ["IsInput"] = true,
            ["IsEditMode"] = false,
            ["AudioInputType"] = AudioInputType.Event
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<DeviceDialog>("Add Prompt", parameters, options);
        
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadDevices();
        }
    }

    private async Task OpenAddOutputDialog()
    {
        var parameters = new DialogParameters
        {
            ["IsInput"] = false,
            ["IsEditMode"] = false
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<DeviceDialog>("Add Audio Output", parameters, options);
        
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadDevices();
        }
    }

    private async Task OpenEditInputDialog(DeviceConfigurationResponse device, AudioInputType inputType)
    {
        var parameters = new DialogParameters
        {
            ["IsInput"] = true,
            ["IsEditMode"] = true,
            ["Device"] = device,
            ["AudioInputType"] = inputType
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<DeviceDialog>($"Edit {device.Name}", parameters, options);
        
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadDevices();
        }
    }

    private async Task OpenEditOutputDialog(DeviceConfigurationResponse device)
    {
        var parameters = new DialogParameters
        {
            ["IsInput"] = false,
            ["IsEditMode"] = true,
            ["Device"] = device
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<DeviceDialog>($"Edit {device.Name}", parameters, options);
        
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadDevices();
        }
    }

    private async Task DeleteInput(string id)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete",
            "Are you sure you want to delete this audio input device?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                var client = HttpClientFactory.CreateClient();
                client.BaseAddress = new Uri("http://localhost:5000");
                var response = await client.DeleteAsync($"/api/devices/inputs/{id}");

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Device deleted successfully", Severity.Success);
                    await LoadDevices();
                }
                else
                {
                    Snackbar.Add($"Failed to delete device: {response.StatusCode}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting device: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteOutput(string id)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete",
            "Are you sure you want to delete this audio output device?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                var client = HttpClientFactory.CreateClient();
                client.BaseAddress = new Uri("http://localhost:5000");
                var response = await client.DeleteAsync($"/api/devices/outputs/{id}");

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Device deleted successfully", Severity.Success);
                    await LoadDevices();
                }
                else
                {
                    Snackbar.Add($"Failed to delete device: {response.StatusCode}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting device: {ex.Message}", Severity.Error);
            }
        }
    }
}
