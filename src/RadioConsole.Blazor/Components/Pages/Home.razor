@page "/"
@rendermode InteractiveServer
@using RadioConsole.Api.Interfaces
@using RadioConsole.Api.Services
@using RadioConsole.Api.Models
@using System.Net.Http.Json
@inject IEnumerable<IAudioInput> AudioInputs
@inject IEnumerable<IAudioOutput> AudioOutputs
@inject IDeviceRegistry DeviceRegistry
@inject IEnvironmentService EnvironmentService
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar

<PageTitle>Audio Control</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Audio Control</MudText>

<!-- Status Section -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" GutterBottom="true">Status</MudText>
    <MudText Typo="Typo.body2">@_statusMessage</MudText>
</MudPaper>

<!-- Music Input Selection -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" GutterBottom="true">Music Input</MudText>
    <MudSelect T="IAudioInput" 
               Label="Select Input" 
               @bind-Value="_selectedInput" 
               Variant="Variant.Outlined"
               AnchorOrigin="Origin.BottomCenter">
        @foreach (var input in _musicInputs)
        {
            <MudSelectItem Value="@input">@input.Name</MudSelectItem>
        }
    </MudSelect>
    @if (_selectedInput != null)
    {
        <MudText Typo="Typo.body2" Class="mt-2">@_selectedInput.Description</MudText>
    }
</MudPaper>

<!-- Output Selection -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" GutterBottom="true">Audio Output</MudText>
    <MudSelect T="IAudioOutput" 
               Label="Select Output" 
               @bind-Value="_selectedOutput" 
               Variant="Variant.Outlined"
               AnchorOrigin="Origin.BottomCenter">
        @foreach (var output in _audioOutputs)
        {
            <MudSelectItem Value="@output">@output.Name</MudSelectItem>
        }
    </MudSelect>
    @if (_selectedOutput != null)
    {
        <MudText Typo="Typo.body2" Class="mt-2">@_selectedOutput.Description</MudText>
    }
</MudPaper>

<!-- Volume Control -->
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" GutterBottom="true">Volume</MudText>
    <MudSlider @bind-Value="_volume" 
               Min="0.0" 
               Max="1.0" 
               Step="0.01"
               Color="Color.Primary"
               ValueLabel="true">
        Volume: @(_volume.ToString("P0"))
    </MudSlider>
</MudPaper>

<!-- Playback Controls -->
<MudGrid>
    <MudItem xs="12" sm="6">
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   FullWidth="true" 
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   OnClick="PlayAsync"
                   Disabled="_isPlaying">
            Play
        </MudButton>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Secondary" 
                   FullWidth="true" 
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Stop"
                   OnClick="StopAsync"
                   Disabled="!_isPlaying">
            Stop
        </MudButton>
    </MudItem>
</MudGrid>

<!-- Test Prompt Section -->
<MudPaper Elevation="2" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6" GutterBottom="true">Test Prompt</MudText>
    <MudGrid>
        <MudItem xs="12" sm="9">
            <MudSelect T="string" 
                       Label="Select Prompt" 
                       @bind-Value="_selectedPromptId" 
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter">
                @foreach (var prompt in _promptDevices)
                {
                    <MudSelectItem Value="@prompt.Id">@prompt.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Info" 
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="PlayPromptAsync"
                       Disabled="string.IsNullOrEmpty(_selectedPromptId) || _selectedOutput == null || _isPlayingPrompt">
                Play
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    private List<IAudioInput> _musicInputs = new();
    private List<IAudioOutput> _audioOutputs = new();
    private List<DeviceConfigurationResponse> _promptDevices = new();
    private IAudioInput? _selectedInput;
    private IAudioOutput? _selectedOutput;
    private string _selectedPromptId = string.Empty;
    private string _statusMessage = "Ready";
    private bool _isPlaying = false;
    private bool _isPlayingPrompt = false;
    private double _volume = 0.5;

    protected override async Task OnInitializedAsync()
    {
        // Combine statically registered and dynamically configured devices
        var allInputs = AudioInputs.Concat(DeviceRegistry.GetAllInputs()).ToList();
        
        // Filter to only show Music inputs
        _musicInputs = allInputs
            .Where(i => i.InputType == AudioInputType.Music)
            .ToList();
        
        _audioOutputs = AudioOutputs.Concat(DeviceRegistry.GetAllOutputs()).ToList();

        // Load prompt devices from API
        await LoadPrompts();

        // Select first available input and output
        _selectedInput = _musicInputs.FirstOrDefault(i => i.IsAvailable);
        _selectedOutput = _audioOutputs.FirstOrDefault(o => o.IsAvailable);

        UpdateStatusMessage();
    }

    private async Task LoadPrompts()
    {
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri("http://localhost:5000");

            var allInputs = await client.GetFromJsonAsync<List<DeviceConfigurationResponse>>("/api/devices/inputs");
            
            if (allInputs != null)
            {
                _promptDevices = allInputs
                    .Where(d => d.AudioInputType == AudioInputType.Event)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading prompts: {ex.Message}", Severity.Warning);
        }
    }

    private async Task PlayAsync()
    {
        if (_selectedInput == null || _selectedOutput == null)
        {
            _statusMessage = "Please select input and output";
            return;
        }

        try
        {
            await _selectedOutput.StartAsync();
            await _selectedInput.StartAsync();
            _isPlaying = true;
            _statusMessage = $"Playing {_selectedInput.Name} through {_selectedOutput.Name}";
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
        }
    }

    private async Task StopAsync()
    {
        if (_selectedInput != null)
            await _selectedInput.StopAsync();

        if (_selectedOutput != null)
            await _selectedOutput.StopAsync();

        _isPlaying = false;
        _statusMessage = "Stopped";
    }

    private async Task PlayPromptAsync()
    {
        if (string.IsNullOrEmpty(_selectedPromptId) || _selectedOutput == null)
        {
            Snackbar.Add("Please select a prompt and output", Severity.Warning);
            return;
        }

        _isPlayingPrompt = true;

        try
        {
            // Get the prompt input from the device registry
            var promptInput = DeviceRegistry.GetInput(_selectedPromptId);
            
            if (promptInput == null)
            {
                Snackbar.Add("Prompt not found", Severity.Error);
                return;
            }

            await _selectedOutput.StartAsync();
            await promptInput.StartAsync();
            
            Snackbar.Add($"Playing prompt: {promptInput.Name}", Severity.Info);
            
            // Auto-stop after duration if available
            if (promptInput.Duration.HasValue)
            {
                await Task.Delay(promptInput.Duration.Value);
                await promptInput.StopAsync();
                Snackbar.Add("Prompt finished", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error playing prompt: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isPlayingPrompt = false;
        }
    }

    private void UpdateStatusMessage()
    {
        if (EnvironmentService.IsSimulationMode)
        {
            _statusMessage = $"Simulation Mode - {EnvironmentService.PlatformDescription}";
        }
        else
        {
            _statusMessage = $"Running on {EnvironmentService.PlatformDescription}";
        }
    }
}
